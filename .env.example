# Local development — copy to `.env` in this directory.
# Production template: config/.env.production.example

# Service
SERVICE_NAME=fleet-iot
LOG_FORMAT=json
# GIN_MODE defaults to release when unset. Set to debug for local development.
# GIN_MODE=debug

# Database
DATABASE_URL=postgres://svc_iag_fleet:iag_fleet_dev@localhost:5432/iag_platform?sslmode=disable
# Optional pgxpool tuning
# DB_MAX_CONNS=30
# DB_MIN_CONNS=2

# Telemetry hub — Redis pub/sub is optional; unset for in-process only
REDIS_URL=redis://localhost:6379/0

# HTTP ingest (cmd/ingest) — ADDR wins over PORT
ADDR=:4080
# PORT=4080

# TCP telemetry gateway (cmd/gateway) — Teltonika Codec 8/8E
IOT_ADDR=:5027

# SinoTrack / HQ-protocol gateway (cmd/sinotrack) — ST-901/906/915 + GT06-era clones
SINOTRACK_ADDR=:5013

# Track replay query caps (cmd/ingest)
# TELEMETRY_TRACK_MAX_DAYS=30
# TELEMETRY_TRACK_MAX_ROWS=50000
